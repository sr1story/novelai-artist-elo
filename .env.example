# NovelAI API Key (required)
# Get your API key from https://novelai.net/ (requires active subscription)
# Go to Account Settings > Get Persistent API Token
NOVELAI_API_KEY=your-api-key-here

# Personal web login. Use at least 8 characters when the app is reachable online.
APP_USERNAME=artist
APP_PASSWORD=replace-with-a-long-private-password

# Optional: NovelAI Generation Parameters
# NAI_STEPS=28
# NAI_IMG_WIDTH=1024
# NAI_IMG_HEIGHT=1024

# Optional: ELO System Parameters
# ELO_DEFAULT=1500
# ELO_K_FACTOR=32

# Optional: Active Pool Settings
# POOL_SIZE=150
# NEW_ARTIST_PROB=0.15
# LOSER_ROTATION_PROB=0.4

# Optional: Server Settings
# SERVER_HOST=127.0.0.1
# SERVER_PORT=7860
# INBROWSER=true

# Optional: Persistent Data Directory
# Set this to the mount path of a persistent cloud disk.
# DATA_DIR=/data

# Optional: Custom Default Prompts
# Use quotes for prompts with spaces/commas. Use {artist_placeholder} where artist tags should go.
# DEFAULT_PROMPT="1girl, fantasy setting, {artist_placeholder}, detailed background"
# NEGATIVE_PROMPT="lowres, bad anatomy, bad hands, text, error"
